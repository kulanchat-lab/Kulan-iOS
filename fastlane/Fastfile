default_platform(:ios)

BUNDLE_ID = "com.kulan.messenger.native"

platform :ios do
  desc "Build a signed Release and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    # No pre-shared .p12: create/fetch the distribution certificate straight from
    # the App Store Connect API key, into the throwaway build keychain.
    cert(
      api_key: api_key,
      keychain_path: ENV["SIGN_KEYCHAIN"],
      keychain_password: ""
    )

    # App Store provisioning profile for the bundle (regenerated to include the cert above).
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: BUNDLE_ID,
      force: true
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    update_code_signing_settings(
      path: "Kulan.xcodeproj",
      use_automatic_signing: false,
      team_id: ENV["ASC_TEAM_ID"],
      targets: ["Kulan"],
      code_sign_identity: "Apple Distribution",
      bundle_identifier: BUNDLE_ID,
      profile_name: profile_name
    )

    build_app(
      project: "Kulan.xcodeproj",
      scheme: "Kulan",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "CURRENT_PROJECT_VERSION=#{ENV['BUILD_NUMBER']} -skipPackagePluginValidation -skipMacroValidation",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { BUNDLE_ID => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
